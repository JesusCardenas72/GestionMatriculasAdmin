{
  "appId": "com.gestionmatriculas.admin",
  "productName": "Gestion Matriculas Admin",
  "directories": {
    "output": "release"
  },
  "files": [
    "dist/**/*",
    "dist-electron/**/*",
    "PergaminoIcon.ico"
  ],
  "win": {
    "target": [
      "portable",
      "dir"
    ],
    "icon": "PergaminoIcon256.ico"
  },
  "portable": {
    "artifactName": "GestionMatriculas-v${version}-Portable.exe"
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true
  }
}
